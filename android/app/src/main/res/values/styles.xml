<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting,
         i.e. while showing launch_background.xml. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@color/launch_background_color</item>
        <item name="android:navigationBarColor">@color/launch_background_color</item>
    </style>

    <!-- Theme applied to the Android Window as soon as Flutter draws its
         first frame. This theme determines the color of the Android
         Window while your Flutter content shows through, and is updated
         to match Flutter's dark UI in main.dart. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
        <item name="android:statusBarColor">@color/launch_background_color</item>
        <item name="android:navigationBarColor">@color/launch_background_color</item>
    </style>
</resources>
